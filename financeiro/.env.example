# Copie este arquivo para .env e preencha com os valores reais
# .env nao vai pro Git (esta no .gitignore)

# Banco de dados (prefixe DB_HOST com "p:" para ativar conexao persistente do mysqli)
DB_HOST=p:HOST_DO_MYSQL
DB_USER=USUARIO
DB_PASS=SENHA
DB_NAME=NOME_DO_BANCO

# Bypass de admin (login de emergencia caso a tabela usuario_atendimento esteja inacessivel)
# Deixe ADMIN_BYPASS_PASS vazio para desativar o bypass
ADMIN_BYPASS_USER=admin
ADMIN_BYPASS_PASS=
